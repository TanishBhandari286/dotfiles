# --- 1. Dynamic Homebrew Initialization ---
{{ if eq .chezmoi.os "darwin" -}}
# Mac M2 Path
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ else if eq .chezmoi.os "linux" -}}
# Linuxbrew Path
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}

# --- 2. Terminal Compatibility ---
if [[ "$TERM" == "xterm-ghostty" ]]; then
  if ! infocmp xterm-ghostty >/dev/null 2>&1; then
    export TERM=xterm-256color
  fi
fi

# Fix for trailing characters on paste (The "E" fix)
unset zle_bracketed_paste

# --- 3. Environment & Paths ---
export EDITOR="nvim"
export PATH="$HOME/.local/share/nvim/mason/bin:$PATH"

# --- 4. History Settings ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS

# --- 5. Vim Keybindings ---
bindkey -v
export KEYTIMEOUT=1

# --- 6. Fast Completions ---
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

# --- 7. Aliases ---
alias e='exit'
alias c='clear'
alias v='nvim'
alias ls='eza --icons --group-directories-first'
alias ll='eza -lh --icons'
alias lg='lazygit'
alias ld='lazydocker'
alias checkup='echo "Target: $(hostname)"; [ -f ~/.ssh/id_ed25519 ] && echo "✅ SSH Key Decrypted" || echo "❌ SSH Key Missing"; [ -d ~/.tmux/plugins/tpm ] && echo "✅ TPM Installed" || echo "❌ TPM Missing"'

# Chezmoi Quick Edits
alias zdot="chezmoi edit ~/.zshrc"
alias tdot="chezmoi edit ~/.tmux.conf"
alias ndot="chezmoi edit ~/.config/nvim/init.lua"

# --- 8. Tool Inits ---
eval "$(starship init zsh)"
eval "$(zoxide init zsh --cmd cd)"
source <(fzf --zsh)

# --- 9. Plugins (OS-Aware Sourcing) ---
{{ if eq .chezmoi.os "darwin" -}}
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{ else if eq .chezmoi.os "linux" -}}
source /home/linuxbrew/.linuxbrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /home/linuxbrew/.linuxbrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{ end -}}

# Final safety for paste bug
unset zle_bracketed_paste
